# Material Definition for BCC Fe

material:num-materials=1

material[1]:material-name=Iron

material[1]:atomic-spin-moment=2.2 !muB

material[1]:initial-spin-direction=random

material[1]:exchange-matrix[1]=2.0e-21

material[1]:damping-constant=0.01
material[1]:uniaxial-anisotropy-constant=5.0e-21

material[1]:uniaxial-anisotropy-direction = 0 , 0 , 1
